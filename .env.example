# ── Feishu (飞书) ──────────────────────────────────────────
FEISHU_APP_ID=cli_xxxx
FEISHU_APP_SECRET=xxxx

# ── Anthropic ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxx

# ── Tuya IoT Open API ─────────────────────────────────────
# 区域选项: cn | us | eu | in（默认 cn）
TUYA_REGION=cn
TUYA_CLIENT_ID=xxxx
TUYA_CLIENT_SECRET=xxxx
# 涂鸦设备 ID（从涂鸦 IoT 平台获取）
TUYA_DEVICE_ID=xxxx
